{
  "name": "inferbench-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "InferBench desktop UI (Electron + React)",
  "author": "Jonathan Martin",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoniMartin27/inferbench.git"
  },
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.460.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.inferbench.app",
    "productName": "InferBench",
    "electronVersion": "33.4.11",
    "npmRebuild": false,
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "!electron/sidecar/**/*"],
    "extraResources": [
      {
        "from": "electron/sidecar/",
        "to": "sidecar/",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
