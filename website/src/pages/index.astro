  <!-- ===== Animación de la demo ===== -->
  <script>
    const $ = (id) => document.getElementById(id);
    const log = $("log");
    const bar = $("bar");
    const phaseLabel = $("phase-label");
    const phasePct = $("phase-pct");
    const mTps = $("m-tps");
    const mTtft = $("m-ttft");
    const mVram = $("m-vram");

    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

    function addLog(text, cls = "text-slate-400") {
      if (!log) return;
      const line = document.createElement("div");
      line.className = cls;
      line.textContent = text;
      log.appendChild(line);
      while (log.childNodes.length > 6) log.removeChild(log.firstChild);
      log.scrollTop = log.scrollHeight;
    }

    async function ramp(setText, from, to, dur, fmt) {
      const start = performance.now();
      return new Promise((resolve) => {
        function frame(now) {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          setText(fmt(from + (to - from) * eased));
          if (p < 1) requestAnimationFrame(frame);
          else resolve();
        }
        requestAnimationFrame(frame);
      });
    }

    async function setPhase(label, target) {
      if (phaseLabel) phaseLabel.textContent = label;
      await ramp((v) => {
        if (bar) bar.style.width = v + "%";
        if (phasePct) phasePct.textContent = Math.round(v) + "%";
      }, parseFloat((bar?.style.width || "0").replace("%", "")) || 0, target, 700, (v) => v);
    }

    async function loop() {
      // reset
      if (mTps) mTps.textContent = "0.0";
      if (mTtft) mTtft.innerHTML = '— <span class="text-sm">ms</span>';
      if (mVram) mVram.innerHTML = '0.0 <span class="text-sm">GB</span>';
      if (bar) bar.style.width = "0%";
      if (log) log.innerHTML = '<div class="text-slate-600">$ inferbench run --auto</div>';

      addLog("→ Detectando hardware… RTX 4060 · 8 GB · 32 GB RAM", "text-slate-500");
      await sleep(700);
      addLog("→ Optimizando: Q4_K_M · ctx 8192 · MoE offload 27 capas", "text-indigo-bright");
      await setPhase("Descargando binario llama.cpp…", 22);
      addLog("✓ llama-server (CUDA) listo", "text-emerald");
      await setPhase("Descargando GGUF desde Hugging Face…", 70);
      addLog("✓ qwen3-30b-a3b-Q4_K_M.gguf · 18.6 GB", "text-emerald");
      await setPhase("Arrancando motor…", 85);
      await sleep(400);

      // TTFT
      if (mTtft) await ramp((v) => { mTtft.innerHTML = Math.round(v) + ' <span class="text-sm">ms</span>'; }, 0, 213, 600, (v) => v);
      addLog("→ TTFT 213 ms · generando…", "text-slate-400");
      await setPhase("Benchmark en vivo…", 100);

      // tok/s + vram suben juntas
      await Promise.all([
        mTps ? ramp((v) => (mTps.textContent = v.toFixed(1)), 0, 47.3, 2200, (v) => v) : null,
        mVram ? ramp((v) => { mVram.innerHTML = v.toFixed(1) + ' <span class="text-sm">GB</span>'; }, 0, 7.4, 2200, (v) => v) : null,
      ]);
      addLog("✓ run completada · 47.3 tok/s · calidad 87/100", "text-emerald");
      if (phaseLabel) phaseLabel.textContent = "Completado ✓";

      await sleep(3200);
      loop();
    }

    // Arranca cuando la demo entra en viewport (respeta prefers-reduced-motion)
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduce) {
      const demo = $("log");
      const obs = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          obs.disconnect();
          loop();
        }
      });
      if (demo) obs.observe(demo);
    } else {
      // estado final estático
      if (mTps) mTps.textContent = "47.3";
      if (mTtft) mTtft.innerHTML = '213 <span class="text-sm">ms</span>';
      if (mVram) mVram.innerHTML = '7.4 <span class="text-sm">GB</span>';
      if (bar) bar.style.width = "100%";
      if (phasePct) phasePct.textContent = "100%";
      if (phaseLabel) phaseLabel.textContent = "Completado ✓";
    }
  </script>
</Layout>
